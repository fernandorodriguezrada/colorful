def main():
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--image", "-i")
    parser.add_argument("--prompt", "-p")
    parser.add_argument("--model", "-m", default=None)
    parser.add_argument("--output", "-o")
    parser.add_argument("--set-default-model")
    parser.add_argument("--set-default-text-model")
    parser.add_argument("--set-output-dir")
    parser.add_argument("--list-models", action="store_true")
    parser.add_argument("--list-text-models", action="store_true")
    parser.add_argument("--no-display", action="store_true")
    parser.add_argument("--diagnose", action="store_true")
    parser.add_argument("--help", "-h", action="store_true")
    args, _ = parser.parse_known_args()

    if args.help:
        print_help()
        return

    if args.set_default_model:
        set_default_model(args.set_default_model)
        return

    if args.set_default_text_model:
        set_default_model(args.set_default_text_model, mode="text")
        return

    if args.set_output_dir:
        set_env("COLORFUL_OUTPUT_DIR", args.set_output_dir)
        return

    if args.list_models:
        list_models()
        return

    if args.list_text_models:
        list_text_models()
        return

    if args.diagnose:
        print(f"\n  chats dir: {CHATS_DIR}")
        print(f"  chats dir exists: {CHATS_DIR.exists()}")
        files = sorted(CHATS_DIR.glob("*.json"))
        print(f"  json files: {len(files)}")
        for f in files:
            try:
                data = json.loads(f.read_text())
                msgs = data.get("messages", [])
                first = next((m["content"][:60] for m in msgs if m["role"] == "user"), "?")
                print(f"    {f.name}  →  {first}")
            except Exception as e:
                print(f"    {f.name}  →  ERROR: {e}")
        return

    api_key = load_api_key()

    if args.prompt and not args.image:
        mode = "text"
        prompt = args.prompt
        model = args.model or resolve_default_model("text")
        img_path = ""
    elif args.image:
        mode = "image"
        img_path = args.image
        if not os.path.exists(img_path):
            print(f"  file not found: {img_path}")
            sys.exit(1)
        prompt = args.prompt
        if not prompt:
            print(f"\n  {rainbow('colorful')} {D}—{R} {I}image mode{R}\n")
            prompt = safe_input(f"  {C}prompt{R} {D}›{R} ").strip()
            if not prompt:
                print("  no prompt provided")
                sys.exit(1)
        model = args.model or resolve_default_model("image")
    else:
        mode = "text"
        img_path = ""
        prompt = ""
        model = args.model or resolve_default_model("text")

    if mode == "text":
        chat_loop(model, api_key, initial_prompt=prompt or None)
        return

    img_name = Path(img_path).name
    model_name = next((n for s, n, *_ in MODELS if s == model), model)

    print(f"\n  {D}{img_name}{R}")
    print(f"  {C}{model_name}{R}")
    print(f"  {I}{prompt}{R}")
    print(f"  {D}generating{R}...", end="", flush=True)

    image_uri = image_to_data_uri(img_path)
    img_bytes, cost = generate(image_uri, prompt, model, api_key)

    if args.output:
        out_path = args.output
    else:
        ts = datetime.now().strftime("%Y%m%d-%H%M%S")
        out_dir = resolve_output_dir() or str(Path(img_path).parent)
        out_path = str(Path(out_dir) / f"colorful-{ts}.png")
    Path(out_path).parent.mkdir(parents=True, exist_ok=True)
    Path(out_path).write_bytes(img_bytes)
    cost_str = f"${cost:.4f}" if isinstance(cost, float) else str(cost)

    print(f"\r  {RAINBOW[3]}done{R}  {D}{cost_str}{R}  → {out_path}")

    if not args.no_display:
        display_image(img_bytes)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print()
        sys.exit(0)
