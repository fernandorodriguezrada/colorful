        return os.environ.get("COLORFUL_TEXT_MODEL") or TEXT_MODELS[0][0]
    return os.environ.get("COLORFUL_MODEL") or MODELS[0][0]


def load_api_key():
    load_dotenv()
    key = os.environ.get("OPENROUTER_API_KEY", "").strip()
    if not key or "your-key" in key or len(key) < 20:
        print(f"\n  {K}API key needed{R}")
        key = safe_input(f"  {C}enter your OpenRouter key{R} {D}(sk-or-v1-...){R} {D}›{R} ").strip()
        if not key:
            print(f"  {K}oops{R}  need an API key to continue")
            sys.exit(1)
        dotenv_path = Path(".env")
        if dotenv_path.exists():
            lines = dotenv_path.read_text().splitlines()
            found = False
            for i, line in enumerate(lines):
                if line.startswith("OPENROUTER_API_KEY="):
                    lines[i] = f"OPENROUTER_API_KEY={key}"
                    found = True
                    break
            if not found:
                lines.append(f"OPENROUTER_API_KEY={key}")
            dotenv_path.write_text("\n".join(lines) + "\n")
        else:
            dotenv_path.write_text(f"OPENROUTER_API_KEY={key}\n")
        print(f"  {T}saved{R}  {D}to .env{R}")
        load_dotenv()
        os.environ["OPENROUTER_API_KEY"] = key
    return key


def image_to_data_uri(path):
    if Image is None:
        print("error: Pillow not installed")
        sys.exit(1)
    img = Image.open(path)
    buf = io.BytesIO()
    fmt = img.format or "PNG"
    img.save(buf, fmt)
    b64 = base64.b64encode(buf.getvalue()).decode()
    mime = f"image/{fmt.lower()}"
    return f"data:{mime};base64,{b64}"


def generate(image_uri, prompt, model, api_key):
    payload = {
        "model": model,
        "prompt": prompt,
        "input_references": [
            {"type": "image_url", "image_url": {"url": image_uri}}
        ],
    }

    headers = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
    }
    resp = requests.post(API_URL, headers=headers, json=payload, timeout=120)
    if resp.status_code != 200:
        err = resp.json().get("error", {}).get("message", resp.text)
        hint = f" {D}(check your API key in .env){R}" if resp.status_code == 401 else ""
        print(f"\r  {R}error{R}  {D}({resp.status_code}){R} {err}{hint}")
        sys.exit(1)
    data = resp.json()
    b64 = data["data"][0]["b64_json"]
    cost = data.get("usage", {}).get("cost")
    if cost is None:
        cost = "?"
    return base64.b64decode(b64), cost


def clear_line():
    sys.stdout.write('\r' + ' ' * 80 + '\r')
    sys.stdout.flush()

def safe_input(prompt=""):
    try:
        result = input(f"{BAR}{prompt}")
        sys.stdout.write(BLOCK)
        sys.stdout.flush()
        return result
    except (EOFError, KeyboardInterrupt):
        clear_line()
        sys.exit(0)

def system_context():
    now = datetime.now()
    import platform
    return (
        f"{now.strftime('%b %d %H:%M')} {now.astimezone().tzinfo} "
        f"{platform.system()} {platform.node()}"
    )

def generate_text(messages, model, api_key):
    payload = {"model": model, "messages": messages}
    headers = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
    }
    resp = requests.post(CHAT_URL, headers=headers, json=payload, timeout=120)
    if resp.status_code != 200:
        err = resp.json().get("error", {}).get("message", resp.text)
        print(f"\r  {R}error{R}  {D}({resp.status_code}){R} {err}")
        sys.exit(1)
    data = resp.json()
    reply = data["choices"][0]["message"]["content"]
    usage = data.get("usage")
    return reply, usage


def save_chat(messages, model):
    CHATS_DIR.mkdir(parents=True, exist_ok=True)
    ts = datetime.now().strftime("%Y%m%d-%H%M%S")
    path = CHATS_DIR / f"{ts}.json"
    path.write_text(json.dumps({"model": model, "messages": messages, "updated": ts}, indent=2))
    return path

def load_chat(path):
    return json.loads(Path(path).read_text())

def list_chats():
    CHATS_DIR.mkdir(parents=True, exist_ok=True)
    files = sorted(CHATS_DIR.glob("*.json"))
    chats = []
    for f in files:
        try:
            data = json.loads(f.read_text())
            msgs = data.get("messages", [])
            first = next((m["content"][:60] for m in msgs if m["role"] == "user"), "?")
            ts = data.get("updated", f.stem)
            chats.append((f, ts, first, data.get("model", "?")))
        except Exception:
            continue
    return sorted(chats, key=lambda x: x[1], reverse=True)

def chat_loop(model, api_key, initial_prompt=None, resume_path=None):
    messages = [{"role": "system", "content": system_context()}]
    info = next((t for t in TEXT_MODELS if t[0] == model), None)
    model_name = info[1] if info else model
    short_name = info[4] if info else model

    if resume_path:
        data = load_chat(resume_path)
        messages = data["messages"]
        model = data.get("model", model)
        info = next((t for t in TEXT_MODELS if t[0] == model), None)
        model_name = info[1] if info else model
        short_name = info[4] if info else model
        print(f"\n  {rainbow('colorful')} {D}—{R} {C}{model_name}{R}  {D}(resumed){R}\n")
        for m in messages:
            if m["role"] == "user":
                print(f"  {C}{USERNAME}{R} > {m['content']}")
            elif m["role"] == "assistant":
                print(f"  {P}{short_name}{R} > ", end="")
                if _rich:
                    RichConsole().print(RichMD(m["content"]))
                else:
                    print(m["content"])
    else:
        print(f"\n  {rainbow('colorful')} {D}—{R} {C}{model_name}{R}\n")

    if initial_prompt:
        messages.append({"role": "user", "content": initial_prompt})
        print(f"  {C}{USERNAME}{R} > {initial_prompt}")
        print(f"  {D}generating{R}... ", end="", flush=True)
        reply, usage = generate_text(messages, model, api_key)
        messages.append({"role": "assistant", "content": reply})
        token_info = ""
        if usage:
            pt = usage.get("prompt_tokens", "?")
            ct = usage.get("completion_tokens", "?")
            tt = usage.get("total_tokens", "?")
            token_info = f"  {D}{tt}t  ↑{pt} ↓{ct}{R}"
        print(f"\r  {RAINBOW[3]}done{R}{token_info}")
        save_chat(messages, model)
        print(f"  {P}{short_name}{R} > ", end="")
        if _rich:
            RichConsole().print(RichMD(reply))
        else:
            print(reply)

    while True:
        try:
            prompt = input(f"{BAR}  {C}{USERNAME}{R} > ").strip()
            sys.stdout.write(BLOCK)
            sys.stdout.flush()
        except (EOFError, KeyboardInterrupt):
            clear_line()
            break

        if not prompt or prompt in ("/exit", "/quit"):
            break

        if prompt == "/chats":
            chats = list_chats()
            if not chats:
                print(f"  {D}no saved chats{R}")
                continue
            print(f"\n  {rainbow('chats')}")
            for i, (path, ts, preview, m) in enumerate(chats[:10], 1):
                print(f"    {i}. {D}{ts[:16]}{R}  {m:<20}  {preview}...")
            print()
            choice = input(f"{BAR}  {D}load{R} {D}#{R} {D}or enter to skip{R} {D}›{R} ").strip()
            sys.stdout.write(BLOCK)
            sys.stdout.flush()
            if choice and choice.isdigit():
                idx = int(choice) - 1
                if 0 <= idx < len(chats):
                    return chat_loop(model, api_key, resume_path=str(chats[idx][0]))
            continue

        if prompt == "/new":
            print(f"  {D}starting fresh chat{R}")
            return chat_loop(model, api_key)

        if prompt.startswith("/model"):
            slug = prompt.split("/model", 1)[-1].strip()
            if slug:
                model = slug
                info = next((t for t in TEXT_MODELS if t[0] == model), None)
                model_name = info[1] if info else model
                short_name = info[4] if info else model
                print(f"  {D}model → {C}{model_name}{R}")
            else:
                print(f"  {C}{model_name}{R}")
            continue

        if prompt == "/trim":
            keep = 10
            if len(messages) > keep + 1:
                sys_msg = messages[0]
                messages = [sys_msg] + messages[-keep:]
                print(f"  {D}trimmed{R}  kept last {keep//2} exchanges  {D}({len(messages)} msgs){R}")
            else:
                print(f"  {D}only {len(messages)-1} messages{R}  nothing to trim")
            continue

        if prompt.startswith("/tokens"):
            total = sum(len(m.get("content","")) for m in messages)
            print(f"  {D}~{total//4} est. tokens{R}  {D}({len(messages)} msgs){R}")
            continue

        messages.append({"role": "user", "content": prompt})
        print(f"  {D}generating{R}... ", end="", flush=True)
        reply, usage = generate_text(messages, model, api_key)
        messages.append({"role": "assistant", "content": reply})
        token_info = ""
        if usage:
            pt = usage.get("prompt_tokens", "?")
            ct = usage.get("completion_tokens", "?")
            tt = usage.get("total_tokens", "?")
            token_info = f"  {D}{tt}t  ↑{pt} ↓{ct}{R}"
        print(f"\r  {RAINBOW[3]}done{R}{token_info}")
        save_chat(messages, model)
        print(f"  {P}{short_name}{R} > ", end="")
        if _rich:
            RichConsole().print(RichMD(reply))
        else:
            print(reply)


def display_image(img_bytes):
    suffix = ".png"
    with tempfile.NamedTemporaryFile(suffix=suffix, delete=False) as f:
        f.write(img_bytes)
        tmp = f.name
    try:
        subprocess.run(
            ["kitty", "+kitten", "icat", tmp],
            check=True,
        )
    except FileNotFoundError:
        ts = datetime.now().strftime("%Y%m%d-%H%M%S")
        out = f"colorful-{ts}.png"
        Path(out).write_bytes(img_bytes)
        print(f"  saved to {out}")
    except subprocess.CalledProcessError:
        print("warning: failed to display in kitty")
    finally:
        os.unlink(tmp)


def save_image(img_bytes, path):
    Path(path).write_bytes(img_bytes)
    print(f"saved to {path}")


def set_env(key, value):
    env_path = Path(__file__).parent / ".env"
    if not env_path.exists():
        env_path.write_text(f"{key}={value}\n")
        print(f"saved {key}={value}")
        return
    lines = env_path.read_text().splitlines()
    found = False
    for i, line in enumerate(lines):
        if line.startswith(f"{key}="):
            lines[i] = f"{key}={value}"
            found = True
            break
    if not found:
        lines.append(f"{key}={value}")
    env_path.write_text("\n".join(lines) + "\n")
    print(f"saved {key}={value}")


