def pick_text_model(default_slug=None):
    default_idx = 1
    if default_slug:
        for i, (slug, *_) in enumerate(TEXT_MODELS, 1):
            if slug == default_slug:
                default_idx = i
                break
    print(f"\n  {rainbow('text model')}")
    for i, (slug, name, cost, _, _) in enumerate(TEXT_MODELS, 1):
        marker = f" {D}(default){R}" if i == default_idx else ""
        print(f"    {i}. {name:<24} {C}{slug:<50}{R} {cost}{marker}")
    print(f"    {len(TEXT_MODELS)+1}. custom\n")
    while True:
        try:
            choice = safe_input(f"  choose [{default_idx}] › ").strip()
            if not choice:
                return TEXT_MODELS[default_idx - 1][0]
            idx = int(choice) - 1
            if 0 <= idx < len(TEXT_MODELS):
                return TEXT_MODELS[idx][0]
            if idx == len(TEXT_MODELS):
                return safe_input("  custom slug › ").strip()
            print(f"  enter 1-{len(TEXT_MODELS)+1}")
        except (ValueError, EOFError):
            print(f"  enter 1-{len(TEXT_MODELS)+1}")


