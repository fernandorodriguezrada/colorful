def interactive_mode(args_model=None):
    print(f"\n  {rainbow('colorful')} {D}—{R} {I}OpenRouter{R}\n")
    print(f"  {rainbow('pick a mode')}")
    print(f"    {K}1{R}   {C}image{R}")
    print(f"    {K}2{R}   {P}text{R}\n")
    mode_choice = safe_input(f"  {D}mode{R} {K}[1]{R} {D}›{R} ").strip()
    is_text = mode_choice == "2"

    if is_text:
        default = resolve_default_model("text")
        model = args_model or default
        if not args_model:
            model = pick_text_model(default)
        return "", "", model, "text"

    print(f"\n  {rainbow('colorful')} {D}—{R} {I}image{R}\n")
    img_path = safe_input(f"  {C}path{R} {D}›{R} ").strip()
    if not img_path:
        print(f"  {K}oops{R}  need an image path")
        sys.exit(1)
    if not os.path.exists(img_path):
        print(f"  {K}oops{R}  {D}{img_path}{R} not found")
        sys.exit(1)
    prompt = safe_input(f"  {C}prompt{R} {D}›{R} ").strip()
    if not prompt:
        print(f"  {K}oops{R}  need a prompt")
        sys.exit(1)
    if args_model:
        model = args_model
    else:
        model = pick_image_model(resolve_default_model("image"))
    return img_path, prompt, model, "image"


