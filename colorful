B = "\x1b[1m"
I = "\x1b[3m"
R = "\x1b[0m"
D = "\x1b[38;2;97;114;133m"
T = "\x1b[38;2;163;241;203m"
C = "\x1b[38;2;177;211;254m"
P = "\x1b[38;2;223;184;255m"
K = "\x1b[38;2;255;183;211m"
RAINBOW = ["\x1b[38;2;255;183;211m", "\x1b[38;2;223;184;255m", "\x1b[38;2;177;211;254m", "\x1b[38;2;163;241;203m", "\x1b[38;2;97;114;133m"]
